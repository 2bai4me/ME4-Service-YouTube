# ME4-YouTube — Beispiel-Konfiguration (kopiere zu .env und passe an)

# === Service-Identität ===
SERVICE_ID=ME4-YOUTUBE
SERVICE_NAME=ME4-YouTube
SERVICE_VERSION=1.0.0

# === Ports (gemäß MCP_ZMQ_STANDARD) ===
HTTP_PORT=8770
ZMQ_PORT=5570
WSSP15_PORT=5690
LOADBALANCER_ZMQ_PORT=5571

# === Auth (LEER lassen = Dev-Mode, offen) ===
API_KEY=ob-youtube-key-2026

# === Worker-Pool / Loadbalancer ===
WORKER_COUNT=2
WORKER_BASE_PORT=8771
AUTO_START_WORKERS=true
LOADBALANCER_STRATEGY=least_loaded

# === CORS / Host ===
CORS_ORIGINS=["http://localhost","http://127.0.0.1","http://localhost:3030","http://localhost:5173"]
HOST=0.0.0.0

# === Daten-Pfade ===
# Standard-Wurzel für Session-Ergebnisse (Notes.md + JSON+MD pro
# Funktions-Aufruf) UND für heruntergeladene Video-/Audio-Dateien.
# Der Baustein zeigt im Chat nur den Pfad — die Daten landen hier.
DATA_DIR=E:\Entwicklungen\ME4-YouTube\Bewegungsdaten
DOWNLOAD_DIR=E:\Entwicklungen\ME4-YouTube\Bewegungsdaten\downloads
MAX_DOWNLOAD_SIZE_MB=500
DOWNLOAD_TIMEOUT_SEC=300

# === Logging ===
LOG_LEVEL=INFO
LOG_FILE=service.log

# === SM-Producer Anbindung ===
SM_PRODUCER_URL=http://localhost:3001
SM_PRODUCER_API_KEY=ob-dev-key-2026
SM_PRODUCER_ENABLED=true

# === Limits ===
MAX_COMMENTS=500
REQUEST_TIMEOUT_SEC=120
