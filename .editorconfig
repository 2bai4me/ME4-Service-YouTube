# EditorConfig is awesome: https://EditorConfig.org
# Enforces consistent coding styles across editors and IDEs.
# This file is the single source of truth — every editor that respects
# EditorConfig will format files accordingly.

root = true

[*]
charset                  = utf-8
end_of_line              = lf
insert_final_newline     = true
trim_trailing_whitespace = true
indent_style             = space
indent_size              = 4

[*.{json,yml,yaml,toml}]
indent_size = 2

[*.md]
# Markdown: trailing whitespace matters (2 spaces = line break)
trim_trailing_whitespace = false

[*.{ts,tsx,js,jsx,cjs,mjs}]
indent_size = 2

[*.py]
# Python: PEP 8 mandates 4 spaces
indent_size = 4

[Makefile]
indent_style = tab

[*.{bat,cmd}]
end_of_line = crlf